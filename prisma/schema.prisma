generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  COMPANY
  ADMIN
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  emailVerified  Boolean         @default(true)
  image          String?
  role           Role            @default(STUDENT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  admin_logs     admin_logs[]
  notifications  notifications[]
  sessions       Session[]
  studentProfile StudentProfile?

  isProfileComplete Boolean @default(false)

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model admin_logs {
  id         String   @id
  adminId    String
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  users      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model cities {
  id       String     @id
  name     String
  stateId  String
  states   states     @relation(fields: [stateId], references: [id], onDelete: Cascade)
  colleges colleges[]

  @@unique([name, stateId])
  @@index([stateId])
}

model colleges {
  id        String           @id
  name      String
  cityId    String
  address   String?
  website   String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime
  cities    cities           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  students  StudentProfile[]

  @@index([cityId])
}

model companies {
  id             String           @id @default(cuid())
  name           String
  slug           String?          @unique
  description    String?
  industry       String?
  logoUrl        String?
  website        String?
  location       String?
  headquarters   String?
  foundedYear    Int?
  employeeCount  String?
  placementStats Json?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  company_visits company_visits[]
}

model company_visits {
  id                   String           @id @default(cuid())
  companyId            String
  title                String
  slug                 String?          @unique
  description          String?
  visitType            VisitType        @default(INTERNSHIP)
  fee                  Float            @default(0)
  threshold            Int              @default(30)
  maxCapacity          Int?
  totalSeats           Int              @default(50)
  availableSeats       Int              @default(50)
  status               VisitStatus      @default(OPEN)
  scheduledDate        DateTime?
  registrationDeadline DateTime?
  duration             String?
  city                 String?
  venue                String?
  meetingPoint         String?
  location             String?
  imageUrl             String?
  highlights           String[]
  includes             String[]
  instructions         String?
  published            Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  companies            companies        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  visit_requests       visit_requests[]
  eligibilityRule      EligibilityRule?

  @@index([companyId])
  @@index([status])
  @@index([visitType])
  @@index([slug])
  @@index([published])
}

model EligibilityRule {
  id                String         @id @default(cuid())
  visitId           String         @unique
  minimumCGPA       Float?
  maximumBacklogs   Int?
  minimumSemester   Int?
  graduationYear    Int?
  allowedBranches   String[]
  allowedColleges   String[]
  genderRestriction String?
  visit             company_visits @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model countries {
  id     String   @id
  name   String   @unique
  code   String   @unique
  states states[]
}

model notifications {
  id        String   @id
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
}

model payments {
  id                String         @id
  visitRequestId    String         @unique
  studentId         String
  amount            Float
  currency          String         @default("INR")
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?        @unique
  razorpaySignature String?
  status            PaymentStatus  @default(PENDING)
  receiptUrl        String?
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  students          StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  visit_requests    visit_requests @relation(fields: [visitRequestId], references: [id], onDelete: Cascade)
  transactions      transactions[]

  @@index([razorpayOrderId])
  @@index([status])
  @@index([studentId])
}

model states {
  id        String    @id
  name      String
  countryId String
  cities    cities[]
  countries countries @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
  @@index([countryId])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  phone  String?
  gender String?
  dob    DateTime?

  // Education
  collegeId      String?
  university     String?
  college        String?
  degree         String?
  branch         String?
  semester       Int?
  graduationYear Int?

  // Academic
  currentCgpa    Float?
  tenthPercent   Float?
  twelfthPercent Float?
  backlogs       Int?   @default(0)

  // Professional
  linkedIn  String?
  github    String?
  portfolio String?

  // Preferences
  preferredCities String[]
  dreamCompanies  String[]

  completionPercentage Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  colleges       colleges?         @relation(fields: [collegeId], references: [id])
  payments       payments[]
  visit_requests visit_requests[]
  skills         StudentSkill[]
  interests      StudentInterest[]
  resume         Resume?

  @@index([collegeId])
  @@index([userId])
}

model transactions {
  id                String          @id
  paymentId         String
  type              TransactionType
  amount            Float
  razorpayPaymentId String?
  status            String
  metadata          Json?
  createdAt         DateTime        @default(now())
  payments          payments        @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model visit_requests {
  id             String         @id @default(cuid())
  studentId      String
  visitId        String
  status         RequestStatus  @default(PENDING)
  notes          String?
  appliedAt      DateTime       @default(now())
  requestedAt    DateTime       @default(now())
  approvedAt     DateTime?
  cancelledAt    DateTime?
  updatedAt      DateTime       @updatedAt
  payments       payments?
  students       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company_visits company_visits @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@unique([studentId, visitId])
  @@index([status])
  @@index([studentId])
  @@index([visitId])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  WAITLISTED
}

enum TransactionType {
  PAYMENT
  REFUND
  RETRY
}

enum VisitStatus {
  OPEN
  FORMING
  THRESHOLD_REACHED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum VisitType {
  INTERNSHIP
  PLACEMENT
  EVENT
  WORKSHOP
  OTHER
}

model Skill {
  id       String         @id @default(cuid())
  name     String         @unique
  students StudentSkill[]
}

model StudentSkill {
  studentId String
  skillId   String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill     Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([studentId, skillId])
}

model Interest {
  id       String            @id @default(cuid())
  name     String            @unique
  students StudentInterest[]
}

model StudentInterest {
  studentId  String
  interestId String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  interest   Interest       @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([studentId, interestId])
}

model Resume {
  id         String   @id @default(cuid())
  studentId  String   @unique
  url        String
  fileName   String
  uploadedAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
